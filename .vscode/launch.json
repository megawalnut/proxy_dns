{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug DNS Proxy",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/dns",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Allow pending breakpoints",
          "text": "set breakpoint pending on",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build dns"
    }
  ]
}
